{
  "name": "ET360 Finale — Daily Reminder Scheduler",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            { "field": "cronExpression", "expression": "0 9 * * *" }
          ]
        }
      },
      "id": "a1e0b2c3-0000-4000-8000-000000000001",
      "name": "Every day at 09:00",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 0]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://www.unilagenergyclub.com/uecdp/api/send-reminders",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={}",
        "options": {
          "timeout": 120000
        }
      },
      "id": "a1e0b2c3-0000-4000-8000-000000000002",
      "name": "Trigger daily reminders",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [240, 0],
      "credentials": {
        "httpHeaderAuth": {
          "id": "SlP9CkfLW3Y0LFO0",
          "name": "Header Auth account"
        }
      }
    }
  ],
  "connections": {
    "Every day at 07:00": {
      "main": [
        [
          { "node": "Trigger daily reminders", "type": "main", "index": 0 }
        ]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1"
  },
  "meta": {
    "note": "Runs once daily at 09:00 (n8n instance timezone — set it to Africa/Lagos). Calls the ET360 reminder endpoint, which decides whether today is a reminder day (every 3 days while >1 week out, then 7-day, 3-day, 1-day, and morning-of at 9am) and emails all registrants accordingly. The 'Header Auth account' credential must send header name EMAIL_SECRET with the same secret value as the site's EMAIL_SECERET env var. Endpoint is idempotent per calendar day — keep this as the only daily trigger."
  },
  "tags": []
}
